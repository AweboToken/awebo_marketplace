{
  "name": "awebo-monorepo",
  "private": true,
  "description": "AWEBO monorepo: Next.js app + EverShop (drops/merch)",
  "workspaces": [
    "awebo",
    "evershop-dev"
  ],
  "scripts": {
    "dev": "concurrently -n next,evershop -c blue,magenta \"npm run dev:web\" \"npm run dev:drops\"",
    "dev:web": "npm run dev --workspace=awebo",
    "dev:drops": "npm run dev --workspace=evershop-dev",
    "build": "npm run build --workspace=awebo",
    "build:drops": "npm run build --workspace=evershop-dev",
    "start": "npm run start --workspace=awebo",
    "start:drops": "npm run start --workspace=evershop-dev",
    "setup:drops": "npm run setup --workspace=evershop-dev"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "next": "14.2.5",
    "@types/react": "18.3.27",
    "@types/react-dom": "18.3.7"
  },
  "overrides": {
    "@types/react": "18.3.27",
    "@types/react-dom": "18.3.7"
  },
  "engines": {
    "node": ">=20"
  }
}
