# Copy to .env.local and fill in values. Never commit .env.local.

# Privy auth
PRIVY_APP_ID=
PRIVY_APP_SECRET=
NEXT_PUBLIC_PRIVY_APP_ID=

# Sanity CMS
SANITY_PROJECT_ID=
SANITY_API_KEY=
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Supabase (session + future app data)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only — never expose to client
SUPABASE_SERVICE_ROLE_KEY=

# EverShop commerce backend (optional — disabled until deployed)
EVERSHOP_URL=http://127.0.0.1:3001
EVERSHOP_ADMIN_EMAIL=
EVERSHOP_ADMIN_PASSWORD=
# Set to true only after EverShop is deployed and wired
AWEBO_EVERSHOP_CHECKOUT=false

# Optional contact form webhook
AWEBO_CONTACT_WEBHOOK_URL=
